// ⚠️ COPIE de la source canonique : smoothbackend/rules/useme/firestore.rules
// Ne PAS éditer ni déployer depuis ce repo — déployer depuis smoothbackend :
//   firebase deploy --only firestore:rules --config firebase.useme.json --project uzme-app
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ================================================================
    // HELPER FUNCTIONS
    // ================================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.role in ['admin', 'superAdmin'];
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        request.auth.token.role == 'superAdmin';
    }

    // ================================================================
    // USERS
    // ================================================================

    // Block owner from rewriting role-related fields client-side.
    // These are managed exclusively by callables:
    //   - `role`              → switchUserRole / approveRoleSwitchRequest
    //   - `archivedProfiles`  → switch* callables (soft-archive)
    //   - `roleSwitchHistory` → switch* callables (annual-limit ledger)
    // Without this guard a user could self-promote to admin client-side.
    // Initial role is set at `create` (signup), where this rule doesn't
    // apply. Admins can still update anything (hard reset, support).
    function ownerCanUpdateUser(userId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isOwner(userId)
          && !changed.hasAny(['role', 'archivedProfiles', 'roleSwitchHistory']);
    }

    // Scan/vue de la carte digitale d'un AUTRE utilisateur : le scanneur
    // incrémente users/{scanné}.cardStats.* (CardStatsService). Autorisé
    // uniquement si la MàJ ne touche QUE cardStats — aucun autre champ
    // du profil n'est modifiable par un tiers.
    function isCardStatsOnlyUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isAuthenticated() && changed.hasOnly(['cardStats']);
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if ownerCanUpdateUser(userId) || isAdmin()
          || isCardStatsOnlyUpdate();
      allow delete: if isOwner(userId);
    }

    match /user_preferences/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /user_notifications/{notifId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    match /user_tokens/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /user_app_config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /user_team/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ================================================================
    // STUDIOS
    // ================================================================

    match /studios/{studioId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ================================================================
    // STUDIO SERVICES & ROOMS
    // ================================================================

    match /useme_studio_services/{serviceId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /useme_studio_rooms/{roomId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ================================================================
    // SESSIONS & BOOKINGS
    // ================================================================

    match /useme_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // Collection réellement ciblée par BookingService côté app
    // (`useme_bookings`) — sans ce match, tout le flux booking Firestore
    // est deny par défaut.
    match /useme_bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // ================================================================
    // ARTISTS & FAVORITES
    // ================================================================

    match /useme_artists/{artistId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /useme_favorites/{favoriteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ================================================================
    // CONVERSATIONS & MESSAGES
    // ================================================================

    match /conversations/{convId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();

      // update requis par le package messaging : réactions emoji
      // (toggleReaction), soft-delete (deleteMessage → isDeleted) et
      // accusés de lecture (markMessagesAsRead → readBy). Sans lui, ces
      // trois actions échouent en permission-denied.
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
      }
    }

    // ================================================================
    // MODÉRATION (signalement UGC — Apple Guideline 1.2)
    // ================================================================

    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update: if isSuperAdmin();
    }

    // ================================================================
    // INVITATIONS
    // ================================================================

    match /team_invitations/{invitationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /studio_invitations/{invitationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ================================================================
    // STUDIO CLAIMS & REQUESTS
    // ================================================================

    match /studio_claims/{claimId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    match /studio_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    match /studio_unavailabilities/{unavailId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ================================================================
    // CALENDAR
    // ================================================================

    match /calendar_tokens/{tokenId} {
      allow read, write: if isOwner(tokenId);
    }

    match /availabilities/{availId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /engineer_time_offs/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ================================================================
    // SUBSCRIPTIONS
    // ================================================================

    match /subscription_tiers/{tierId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /subscriptions/{subId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ================================================================
    // PAYMENT
    // ================================================================

    match /payment_accounts/{accountId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    match /payment_distributions/{distId} {
      allow read: if isAuthenticated();
    }

    // ================================================================
    // APP CONFIG
    // ================================================================

    match /app_config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /app_deposit/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /app_permissions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /app_releases/{releaseId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /releases/{releaseId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /features/{featureId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ================================================================
    // AI
    // ================================================================

    match /ai_conversations/{convId} {
      allow read, write: if isAuthenticated();

      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }

    match /ai_settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /ai_actions_log/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // ================================================================
    // DEVICE SESSIONS & SECURITY
    // ================================================================

    match /device_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /encryption_ivs/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ================================================================
    // CONTACTS & NETWORK
    // ================================================================

    match /user_contacts/{contactId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /user_invitations/{invitationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // ================================================================
    // COUNTERS & MISC
    // ================================================================

    match /counters/{counterId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /activity/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // ================================================================
    // PIONEER PROGRAMS
    // ================================================================
    // Read = any authenticated (clients need to know if a program exists
    // and which benefits apply). Writes only via callables — deny direct
    // client writes to keep the distribute / archive flow server-side.

    match /pioneer_programs/{programId} {
      allow read: if isAuthenticated();
      allow write: if false;

      match /recipients/{uid} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    // ================================================================
    // FEATURE FLAGS
    // ================================================================
    // Same shape as pioneer_programs: read by any authenticated user
    // (the Flutter FeatureFlags helper subscribes to the whole collection),
    // writes only via the upsertFeatureFlag / deleteFeatureFlag callables.

    match /feature_flags/{flagKey} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ================================================================
    // ROLE SWITCH REQUESTS — Phase E3
    // ================================================================
    // Created by users (via the requestRoleSwitchArchive callable) when
    // they hit blocking conditions and want admin help. Read by the
    // owner (so they can see their own pending request) and by admins
    // (Phase E5 dashboard). All writes go through callables — direct
    // client writes blocked.

    match /role_switch_requests/{requestId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }
  }
}
