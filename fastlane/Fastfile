default_platform(:ios)

# ──────────────────────────────────────────────
# Android
# ──────────────────────────────────────────────

platform :android do
  desc "Deploy AAB to Google Play (internal testing)"
  lane :deploy do
    aab_path = ENV["AAB_PATH"] || "../build/app/outputs/bundle/release/app-release.aab"
    upload_to_play_store(
      track: "internal",
      aab: aab_path,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: "draft"
    )
  end

  desc "Promote internal to production"
  lane :promote do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "production",
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end

# ──────────────────────────────────────────────
# iOS
# ──────────────────────────────────────────────

platform :ios do
  desc "Install signing certificates via Match (before flutter build)"
  lane :setup_signing do
    setup_ci if ENV["CI"]

    # Use App Store Connect API key for auth (no interactive 2FA needed)
    if ENV["ASC_KEY_ID"] && ENV["ASC_ISSUER_ID"] && ENV["ASC_KEY_CONTENT"]
      api_key = app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_content: ENV["ASC_KEY_CONTENT"],
        is_key_content_base64: true
      )
    end

    match(
      type: "appstore",
      readonly: is_ci && !ENV["MATCH_FORCE"],
      force: ENV["MATCH_FORCE"] == "true",
      api_key: defined?(api_key) ? api_key : nil
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/Runner.xcodeproj",
      team_id: ENV["TEAM_ID"] || "A24549KKK4",
      bundle_identifier: "com.smoothandesign.useme",
      profile_name: "match AppStore com.smoothandesign.useme",
      code_sign_identity: "Apple Distribution"
    )
  end

  desc "Upload IPA to TestFlight"
  lane :deploy do
    ipa_path = ENV["IPA_PATH"] || "../build/ios/ipa/useme.ipa"

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    upload_to_testflight(
      ipa: ipa_path,
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Promote TestFlight build to App Store"
  lane :promote do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    deliver(
      api_key: api_key,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end
end
