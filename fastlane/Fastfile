default_platform(:ios)

# ──────────────────────────────────────────────
# Android
# ──────────────────────────────────────────────

platform :android do
  desc "Deploy AAB to Google Play (internal testing)"
  lane :deploy do
    aab_path = ENV["AAB_PATH"] || "../build/app/outputs/bundle/release/app-release.aab"

    # Per-locale release notes : supply (alias upload_to_play_store) v2+ ne
    # supporte plus l'argument `release_notes:` direct. Le workflow GHA écrit
    # les changelogs dans fastlane/metadata/android/{locale}/changelogs/
    # {versionCode,default}.txt avant cette étape — on active simplement
    # metadata_path + l'upload sélectif des changelogs uniquement.
    has_notes = (ENV["RELEASE_NOTES_FR"] && !ENV["RELEASE_NOTES_FR"].empty?) ||
                (ENV["RELEASE_NOTES_EN"] && !ENV["RELEASE_NOTES_EN"].empty?)

    upload_to_play_store(
      track: "internal",
      aab: aab_path,
      metadata_path: "fastlane/metadata/android",
      skip_upload_metadata: true,
      skip_upload_changelogs: !has_notes,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: "draft"
    )
  end

  desc "Promote internal to production"
  lane :promote do
    # Changelogs are uploaded at deploy time (track: internal). supply cannot
    # attach changelogs on a track-promote without an explicit :version_code,
    # so we skip them here unconditionally.
    upload_to_play_store(
      track: "internal",
      track_promote_to: "production",
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end

# ──────────────────────────────────────────────
# iOS
# ──────────────────────────────────────────────

platform :ios do
  desc "Install signing certificates via Match (before flutter build)"
  lane :setup_signing do
    setup_ci if ENV["CI"]

    # Use App Store Connect API key for auth (no interactive 2FA needed)
    if ENV["ASC_KEY_ID"] && ENV["ASC_ISSUER_ID"] && ENV["ASC_KEY_CONTENT"]
      api_key = app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_content: ENV["ASC_KEY_CONTENT"],
        is_key_content_base64: true
      )
    end

    match(
      type: "appstore",
      readonly: is_ci && !ENV["MATCH_FORCE"],
      force: ENV["MATCH_FORCE"] == "true",
      api_key: defined?(api_key) ? api_key : nil
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/Runner.xcodeproj",
      team_id: ENV["TEAM_ID"] || "A24549KKK4",
      bundle_identifier: "com.smoothandesign.useme",
      profile_name: "match AppStore com.smoothandesign.useme",
      code_sign_identity: "Apple Distribution"
    )
  end

  desc "Upload IPA to TestFlight"
  lane :deploy do
    ipa_path = ENV["IPA_PATH"] || "../build/ios/ipa/useme.ipa"

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    # "What to test" notes for TestFlight beta testers. Falls back to
    # blank if the deploy workflow couldn't extract the section.
    changelog = ENV["RELEASE_NOTES_EN"] && !ENV["RELEASE_NOTES_EN"].empty? \
      ? ENV["RELEASE_NOTES_EN"] : nil

    upload_to_testflight(
      ipa: ipa_path,
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: changelog
    )
  end

  desc "Promote TestFlight build to App Store"
  lane :promote do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    # Per-locale "What's new" notes shown on the App Store.
    notes = {}
    notes["fr-FR"] = ENV["RELEASE_NOTES_FR"] if ENV["RELEASE_NOTES_FR"] && !ENV["RELEASE_NOTES_FR"].empty?
    notes["en-US"] = ENV["RELEASE_NOTES_EN"] if ENV["RELEASE_NOTES_EN"] && !ENV["RELEASE_NOTES_EN"].empty?

    deliver(
      api_key: api_key,
      skip_binary_upload: true,
      skip_metadata: notes.empty?,
      skip_screenshots: true,
      release_notes: notes.empty? ? nil : notes,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end
end
